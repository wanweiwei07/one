# Default: treat as text, normalize line endings to LF in the repo
* text=auto eol=lf

# ---- Source / config (explicit text, LF) ----
*.py       text eol=lf
*.pyi      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.sh       text eol=lf
*.xml      text eol=lf
*.urdf     text eol=lf
*.xacro    text eol=lf
*.dae      text eol=lf
*.launch   text eol=lf
*.gitignore      text eol=lf
*.gitattributes  text eol=lf

# ---- Binary: never touch line endings, never diff as text ----
*.stl      binary
*.obj      binary
*.ply      binary
*.glb      binary
*.fbx      binary
*.npy      binary
*.npz      binary
*.pkl      binary
*.pth      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.bmp      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar      binary
*.gz       binary
*.7z       binary
*.so       binary
*.pyd      binary
*.dll      binary
*.exe      binary
